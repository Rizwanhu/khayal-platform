# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
#   cp .env.example .env
#
# Supabase — Project Settings → API (https://supabase.com/dashboard)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here

# Phone sign-in (no SMS OTP): shared password for synthetic auth emails (phone+N@khayal.app).
# In Supabase Dashboard → Authentication → Providers → Email: turn OFF "Confirm email".
PHONE_AUTH_PASSWORD=choose_a_long_random_secret_here

# --- TEMPORARY QA: skip phone auth and use fixed test users ---
# DEV_OTP_BYPASS=true
# DEV_BYPASS_EMAIL=dev@example.com
# DEV_BYPASS_PASSWORD=your_password
# Or per-role: DEV_BYPASS_PATIENT_EMAIL, DEV_BYPASS_PATIENT_PASSWORD, etc.

# Optional: only for trusted server-side scripts or CI that must bypass RLS.
# Never ship the service role key inside the mobile app.
# SUPABASE_SERVICE_ROLE_KEY=

# Push (add when you configure FCM / APNs)
# FCM_SERVER_KEY=
