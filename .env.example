# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
#   cp .env.example .env
#
# Supabase — Project Settings → API (https://supabase.com/dashboard)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here

# --- TEMPORARY: skip real SMS/OTP while Twilio/TFA is sorted out ---
# Set DEV_OTP_BYPASS=true and add three Auth users (email+password) in Supabase
# matching each role. "Verify" accepts ANY 6 digits; real OTP code is ignored.
# REMOVE or set false before any public / store build.
#
# DEV_OTP_BYPASS=false
# DEV_BYPASS_PATIENT_EMAIL=patient@example.com
# DEV_BYPASS_PATIENT_PASSWORD=your_password
# DEV_BYPASS_CAREGIVER_EMAIL=caregiver@example.com
# DEV_BYPASS_CAREGIVER_PASSWORD=your_password
# DEV_BYPASS_DOCTOR_EMAIL=doctor@example.com
# DEV_BYPASS_DOCTOR_PASSWORD=your_password

# Optional: only for trusted server-side scripts or CI that must bypass RLS.
# Never ship the service role key inside the mobile app.
# SUPABASE_SERVICE_ROLE_KEY=

# Push (add when you configure FCM / APNs)
# FCM_SERVER_KEY=
# or use google-services.json / GoogleService-Info.plist in platform folders (also gitignored if sensitive)
