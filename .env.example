# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
#   cp .env.example .env
#
# Supabase — Project Settings → API (https://supabase.com/dashboard)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional: only for trusted server-side scripts or CI that must bypass RLS.
# Never ship the service role key inside the mobile app.
# SUPABASE_SERVICE_ROLE_KEY=

# Push (add when you configure FCM / APNs)
# FCM_SERVER_KEY=
# or use google-services.json / GoogleService-Info.plist in platform folders (also gitignored if sensitive)
